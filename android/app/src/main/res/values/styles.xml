<?xml version="1.0" encoding="utf-8"?>
<resources>

    <color name="colorPrimary">#05050f</color>
    <color name="colorPrimaryDark">#05050f</color>
    <color name="colorAccent">#05050f</color>

    <!-- Base application theme. -->
    <style name="AppTheme" parent="Theme.AppCompat.NoActionBar">
        <!-- Dark background -->
        <item name="colorPrimary">#05050f</item>
        <item name="colorPrimaryDark">#05050f</item>
        <item name="colorAccent">#05050f</item>
        <item name="android:windowBackground">#05050f</item>
        <item name="android:statusBarColor">#05050f</item>
        <item name="android:navigationBarColor">#05050f</item>
        <item name="android:windowLightStatusBar">false</item>
        <!-- Edge-to-edge support -->
        <item name="android:windowLayoutInDisplayCutoutMode">shortEdges</item>
        <item name="android:enforceStatusBarContrast">false</item>
        <item name="android:enforceNavigationBarContrast">false</item>
    </style>

    <style name="AppTheme.NoActionBar" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:background">@null</item>
        <item name="android:windowBackground">#05050f</item>
        <item name="android:statusBarColor">#05050f</item>
        <item name="android:navigationBarColor">#05050f</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <style name="AppTheme.NoActionBarLaunch" parent="Theme.SplashScreen">
        <item name="android:windowBackground">#05050f</item>
        <item name="windowSplashScreenBackground">#05050f</item>
        <item name="android:statusBarColor">#05050f</item>
        <item name="android:navigationBarColor">#05050f</item>
    </style>
</resources>

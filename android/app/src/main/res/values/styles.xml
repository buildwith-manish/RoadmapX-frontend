<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Base application theme — dark, no white flash -->
    <style name="AppTheme" parent="Theme.AppCompat.NoActionBar">
        <item name="colorPrimary">#05050f</item>
        <item name="colorPrimaryDark">#05050f</item>
        <item name="colorAccent">#05050f</item>
        <item name="android:windowBackground">#05050f</item>
        <item name="android:statusBarColor">#05050f</item>
        <item name="android:navigationBarColor">#05050f</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <style name="AppTheme.NoActionBar" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:background">@null</item>
        <item name="android:windowBackground">#05050f</item>
        <item name="android:statusBarColor">#05050f</item>
        <item name="android:navigationBarColor">#05050f</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <style name="AppTheme.NoActionBarLaunch" parent="Theme.SplashScreen">
        <item name="android:windowBackground">#05050f</item>
    </style>
</resources>
